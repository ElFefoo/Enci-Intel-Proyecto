# =============================================================
# ENCI-INTEL BACKEND — Variables de entorno
# Copiar como backend/.env y completar valores
# NUNCA commitear .env con valores reales
# =============================================================

# --- GCP / Firebase ---
GCP_PROJECT_ID=enci-intel-dev
GCP_REGION=us-central1
FIREBASE_PROJECT_ID=enci-intel-dev

# --- Vertex AI ---
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-pro

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# --- Desarrollo local: bypass de autenticación Firebase ---
# Poner true para omitir validación JWT (SOLO LOCAL)
DISABLE_AUTH=true

# --- Desarrollo local: mock de Gemini sin Vertex AI ---
# Poner true para usar respuesta simulada (SOLO LOCAL)
# Poner false cuando tengas GOOGLE_APPLICATION_CREDENTIALS configurado
USE_GEMINI_MOCK=true

# --- Firestore Emulator (opcional) ---
# Descomenta si usas el emulador local de Firestore
# FIRESTORE_EMULATOR_HOST=localhost:8080

# --- Cloud Tasks ---
CLOUD_TASKS_QUEUE=enci-intel-agents
CLOUD_TASKS_HANDLER_URL=http://localhost:8000/internal/agents/run
