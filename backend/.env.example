# =============================================================
# ENCI-INTEL BACKEND — Variables de entorno
# Copiar como backend/.env y completar valores
# NUNCA commitear .env con valores reales
# =============================================================

# --- GCP / Firebase ---
GCP_PROJECT_ID=enci-intel-dev
GCP_REGION=us-central1
FIREBASE_PROJECT_ID=enci-intel-dev

# --- Modo LLM ---
# mock     → sin API, sin costo (default)
# groq     → Llama 3.3 70B GRATIS ← recomendado para desarrollo
# api_key  → Gemini API Key de AI Studio
# vertex   → Vertex AI GCP (produccion)
GEMINI_MODE=mock

# --- Groq (GRATIS, sin tarjeta) ---
# Registro y API Key en: https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# --- Gemini API Key (si GEMINI_MODE=api_key) ---
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_API_MODEL=gemini-2.0-flash

# --- Vertex AI (solo si GEMINI_MODE=vertex) ---
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-pro

# --- Rate limiting chat ---
CHAT_RATE_LIMIT_PER_DAY=50

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# --- Desarrollo local: bypass Firebase Auth ---
DISABLE_AUTH=true

# --- Cloud Tasks ---
CLOUD_TASKS_QUEUE=enci-intel-agents
CLOUD_TASKS_HANDLER_URL=http://localhost:8000/internal/agents/run
