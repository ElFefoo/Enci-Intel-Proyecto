# =============================================================
# ENCI-INTEL BACKEND — Variables de entorno
# Copiar como backend/.env y completar valores
# NUNCA commitear .env con valores reales
# =============================================================

# --- GCP / Firebase ---
GCP_PROJECT_ID=enci-intel-dev
GCP_REGION=us-central1
FIREBASE_PROJECT_ID=enci-intel-dev

# --- Vertex AI (solo si GEMINI_MODE=vertex) ---
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-pro

# --- Gemini API Key (si GEMINI_MODE=api_key) ---
# Obtener GRATIS en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_API_MODEL=gemini-1.5-flash

# --- Modo Gemini ---
# mock     -> respuesta hardcodeada, sin API, sin costo (default)
# api_key  -> Gemini API Key de AI Studio (GRATIS, recomendado para desarrollo)
# vertex   -> Vertex AI GCP (produccion, de pago)
GEMINI_MODE=mock

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# --- Desarrollo local: bypass Firebase Auth ---
# true = omite validacion JWT (SOLO LOCAL, NUNCA en produccion)
DISABLE_AUTH=true

# --- Firestore Emulator (opcional) ---
# Descomenta si usas el emulador local de Firestore
# FIRESTORE_EMULATOR_HOST=localhost:8080

# --- Cloud Tasks ---
CLOUD_TASKS_QUEUE=enci-intel-agents
CLOUD_TASKS_HANDLER_URL=http://localhost:8000/internal/agents/run
