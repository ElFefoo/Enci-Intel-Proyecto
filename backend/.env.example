# GCP
GCP_PROJECT_ID=enci-intel-prod
GCP_REGION=us-central1
FIRESTORE_DATABASE=(default)

# Firebase Auth (Identity Platform)
# En Cloud Run se usa Application Default Credentials (ADC) — no se necesita archivo JSON
# Solo necesitas FIREBASE_PROJECT_ID en produccion
FIREBASE_PROJECT_ID=enci-intel-prod

# Solo para desarrollo local (apunta al archivo de service account descargado de Firebase Console)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Vertex AI
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-pro

# Cloud Tasks
CLOUD_TASKS_QUEUE=enci-intel-agents
CLOUD_TASKS_HANDLER_URL=https://api.enci-intel.encipharm.cl/internal/agents/run

# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,https://app.enci-intel.encipharm.cl
