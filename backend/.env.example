APP_ENV=development
DEBUG=true

# GCP
GCP_PROJECT_ID=enci-intel-prod
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Keycloak JWT
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=enci-intel
KEYCLOAK_AUDIENCE=enci-intel-backend

# Cloud Tasks
CLOUD_TASKS_QUEUE=enci-intel-agents
INTERNAL_API_SECRET=change-me-in-production

# Firestore (emulador local)
# FIRESTORE_EMULATOR_HOST=localhost:8888
